# ──────────────────────────────────────────────
# SOC Platform — Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to Git
# ──────────────────────────────────────────────

# ── PostgreSQL ──────────────────────────────────
PG_HOST=postgres
PG_PORT=5432
PG_DB=soc_db
PG_USER=soc_app
PG_PASSWORD=changeme123

# Full async DSN used by SQLAlchemy
DATABASE_URL=postgresql+asyncpg://soc_app:changeme123@postgres:5432/soc_db

# ── OpenSearch ──────────────────────────────────
OS_HOST=opensearch
OS_PORT=9200
OS_PASSWORD=Admin@SOC123!
# Set to false for local dev (security plugin disabled)
OS_USE_SSL=false

# ── Kafka ───────────────────────────────────────
KAFKA_BOOTSTRAP=kafka:9092
KAFKA_CONSUMER_GROUP_PARSER=soc-parser-group
KAFKA_CONSUMER_GROUP_DETECTION=soc-detection-group
KAFKA_TOPIC_RAW=raw.logs
KAFKA_TOPIC_NORMALIZED=normalized.logs
KAFKA_TOPIC_ALERTS=alerts
KAFKA_TOPIC_ENRICHED=enriched.alerts

# ── Redis ───────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# ── JWT Authentication ──────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=REPLACE_WITH_64_HEX_CHARS
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── External Threat Intel APIs (optional for MVP) ──
ABUSEIPDB_API_KEY=
VT_API_KEY=
GEOIP_DB_PATH=/data/GeoLite2-City.mmdb

# ── Service Ports ───────────────────────────────
INGESTION_PORT=8001
API_GATEWAY_PORT=8000

# ── Admin Seed User (for first-run setup) ───────
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@soc.local
ADMIN_PASSWORD=Admin@SOC123!
